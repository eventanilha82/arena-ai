# Copie para win/.env e edite localmente. Não commite win/.env.
ARENA_WIN_HOST=147.224.175.141
ARENA_WIN_USER=opc
ARENA_WIN_REMOTE_ROOT=C:/arena-ai

# Gate de QA na VM Windows:
#   smoke    gate rápido antes do build
#   validate gate mais amplo
#   aaa      gate visual/performance completo, se fizer sentido para o bundle enviado
#   none     apenas empacota
ARENA_WIN_QA=smoke

# Espaço local para senha. Mantenha vazio em arquivos commitados. Use a senha
# inicial da OCI de forma interativa no primeiro RDP; depois prefira chave SSH.
ARENA_WIN_INITIAL_PASSWORD=
ARENA_WIN_PASSWORD=
